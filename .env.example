# caléna — The Threshold · environment variables (names only — NEVER commit real values)
# Real values are provided by the deploy environment (Vercel project settings).

# Supabase project — the form route handler inserts into public.invitation_requests.
# anon / publishable key is INSERT-only on that table (RLS); it cannot read rows.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Hero film stand-in toggle.
# Unset / "false" → ships the animated-glass stand-in (default).
# "true" → wires the real <video> loop (poster + mobile/reduced-motion fallback).
NEXT_PUBLIC_HERO_FILM_ENABLED=false

# Resend transactional email (GL-J1). Sends stay DARK until the key is present —
# with no key, lib/email.ts no-ops gracefully and never blocks a request.
# CALENA_FROM_EMAIL overrides the in-code default `caléna <concierge@calena.com.au>`.
RESEND_API_KEY=
CALENA_FROM_EMAIL=

# Real App Store listing URL once published (placeholder until GA).
CALENA_APP_STORE_URL=

# Membership pricing flag (GL-J4 / counsel gate GL-C1-1).
# Unset / "false" → priced join routes (Standing, Activate) reveal NO figures
# (quiet "by invitation" placeholder, noindex). "true" → priced surfaces live —
# do NOT flip until counsel clears the price/founding wording.
NEXT_PUBLIC_MEMBERSHIP_PRICING_LIVE=false
